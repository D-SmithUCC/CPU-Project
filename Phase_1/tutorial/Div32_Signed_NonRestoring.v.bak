module Div32_Signed_NonRestoring(
    input  wire        clock,
    input  wire        clear,
    input  wire        start,
    input  wire [31:0] dividend,
    input  wire [31:0] divisor,
    output reg         done,
    output reg         div0,
    output reg  [31:0] quotient,
    output reg  [31:0] remainder
);

    // Signs and magnitudes
    wire [31:0] dvd_mag;
    wire [31:0] dvs_mag;
    wire dvd_neg, dvs_neg;

    Abs32 ABS_DVD(.x(dividend), .y(dvd_mag), .is_neg(dvd_neg));
    Abs32 ABS_DVS(.x(divisor),  .y(dvs_mag), .is_neg(dvs_neg));

    // quotient sign = dvd_neg XOR dvs_neg
    wire qneg;
    XorGate #(.WIDTH(1)) XSGN(.a(dvd_neg), .b(dvs_neg), .y(qneg));

    // Internal state
    reg  [31:0] Q;          // running quotient magnitude
    reg  [31:0] M;          // divisor magnitude
    reg  [32:0] Aacc;       // signed accumulator (33-bit)
    reg  [31:0] Qshifted;
    reg  [32:0] Ashifted;

    reg  [31:0] count;      // use 32-bit counter (no '+')
    reg         busy;

    // count_next = count + 1 via RCA32_Cout
    wire [31:0] count_next;
    wire count_cout_unused;
    RCA32_Cout INC_COUNT(
        .A(count),
        .B(32'd0),
        .Cin(1'b1),
        .Sum(count_next),
        .Cout(count_cout_unused)
    );

    // M as 33-bit positive
    wire [32:0] M33;
    assign M33 = {1'b0, M};

    // A +/- M (non-restoring step)
    wire [32:0] A_plus_M;
    wire [32:0] A_minus_M;

    Add33 ADD_AM (
        .A(Ashifted),
        .B(M33),
        .Cin(1'b0),
        .Sum(A_plus_M)
    );

    // A - M = A + (-M)
    wire [32:0] negM33;
    Neg33 NEG_M(.x(M33), .y(negM33));

    Add33 SUB_AM (
        .A(Ashifted),
        .B(negM33),
        .Cin(1'b0),
        .Sum(A_minus_M)
    );

    // Not of A sign (for quotient bit setting)
    wire A_nonneg;
    NotGate #(.WIDTH(1)) N_A_SIGN(.a(Aacc[32]), .y(A_nonneg)); // if sign=0 => nonneg=1

    // ---- final restore (if A < 0 then A = A + M) ----
    wire [32:0] A_restored;
    // if Aacc[32]==1 -> add M else keep
    // build mux per bit
    genvar k;
    generate
        for (k = 0; k < 33; k = k + 1) begin : GEN_RESTORE_MUX
            wire sel_keep, sel_add, nsel;
            NotGate #(.WIDTH(1)) N0(.a(Aacc[32]), .y(nsel)); // nsel=1 when A>=0

            // A_restored = (Aacc & nsel) | ((A_plus_M_current) & sel)
            // We'll compute A_plus_M for restore from current Aacc (not shifted):
            // Use Add33 on (Aacc + M33)
        end
    endgenerate
    // (we’ll compute restore combinationally below without loops using a second Add33 + mux)
    wire [32:0] Aacc_plus_M;
    Add33 REST_ADD(.A(Aacc), .B(M33), .Cin(1'b0), .Sum(Aacc_plus_M));

    wire [32:0] Afinal;
    generate
        for (k = 0; k < 33; k = k + 1) begin : GEN_RESTORE2
            wire nsel, keep_bit, add_bit;
            NotGate #(.WIDTH(1)) N0(.a(Aacc[32]), .y(nsel));
            AndGate #(.WIDTH(1)) A0(.a(Aacc[k]),       .b(nsel),      .y(keep_bit));
            AndGate #(.WIDTH(1)) A1(.a(Aacc_plus_M[k]),.b(Aacc[32]),  .y(add_bit));
            OrGate  #(.WIDTH(1)) O0(.a(keep_bit),      .b(add_bit),   .y(Afinal[k]));
        end
    endgenerate

    // Apply signs at the end
    wire [31:0] Q_signed;
    wire [31:0] R_signed;

    wire [31:0] Q_neg;
    wire [31:0] R_neg;
    Neg32 NEGQ(.x(Q),          .y(Q_neg));
    Neg32 NEGR(.x(Afinal[31:0]), .y(R_neg));

    // Q_signed = qneg ? -Q : Q
    generate
        for (k = 0; k < 32; k = k + 1) begin : GEN_QSIGN
            wire nsel, keep_bit, neg_bit;
            NotGate #(.WIDTH(1)) N0(.a(qneg), .y(nsel));
            AndGate #(.WIDTH(1)) A0(.a(Q[k]),     .b(nsel), .y(keep_bit));
            AndGate #(.WIDTH(1)) A1(.a(Q_neg[k]), .b(qneg), .y(neg_bit));
            OrGate  #(.WIDTH(1)) O0(.a(keep_bit), .b(neg_bit), .y(Q_signed[k]));
        end
    endgenerate

    // R_signed = dvd_neg ? -Rmag : Rmag  (remainder sign matches dividend)
    generate
        for (k = 0; k < 32; k = k + 1) begin : GEN_RSIGN
            wire nsel, keep_bit, neg_bit;
            NotGate #(.WIDTH(1)) N0(.a(dvd_neg), .y(nsel));
            AndGate #(.WIDTH(1)) A0(.a(Afinal[31:0][k]), .b(nsel),    .y(keep_bit));
            AndGate #(.WIDTH(1)) A1(.a(R_neg[k]),        .b(dvd_neg), .y(neg_bit));
            OrGate  #(.WIDTH(1)) O0(.a(keep_bit),        .b(neg_bit), .y(R_signed[k]));
        end
    endgenerate

    // Main sequential
    always @(posedge clock) begin
        if (clear) begin
            done      <= 1'b0;
            div0      <= 1'b0;
            quotient  <= 32'b0;
            remainder <= 32'b0;

            Q         <= 32'b0;
            M         <= 32'b0;
            Aacc      <= 33'd0;

            count     <= 32'd0;
            busy      <= 1'b0;
        end else begin
            done <= 1'b0;
            div0 <= 1'b0;

            if (start && !busy) begin
                // divisor == 0?
                if (divisor == 32'b0) begin
                    quotient  <= 32'b0;
                    remainder <= 32'b0;
                    div0      <= 1'b1;
                    done      <= 1'b1;
                    busy      <= 1'b0;
                end else begin
                    Q     <= dvd_mag;
                    M     <= dvs_mag;
                    Aacc  <= 33'd0;
                    count <= 32'd0;
                    busy  <= 1'b1;
                end
            end

            if (busy) begin
                // Shift left (A,Q) combined:
                // Ashifted = {Aacc[31:0], Q[31]}
                // Qshifted = {Q[30:0], 0}
                Ashifted <= {Aacc[31:0], Q[31]};
                Qshifted <= {Q[30:0], 1'b0};

                // Non-restoring step using shifted values (RHS evaluated before updates)
                // If Ashifted >= 0: A = Ashifted - M else A = Ashifted + M
                if ({Aacc[31:0], Q[31]}[32] == 1'b0) begin
                    Aacc <= A_minus_M;
                end else begin
                    Aacc <= A_plus_M;
                end

                // Quotient bit = 1 if new Aacc >= 0 else 0
                // We compute from the same decision result sign using mux:
                // If result sign is 0 => set Qshifted[0]=1
                // Since we can't use ternary, do it with gates in sequential style:
                // We'll just assign Q <= Qshifted with LSB overwritten next cycle based on Aacc sign.
                Q <= Qshifted;

                // increment count (module-based)
                count <= count_next;

                // Stop after 32 iterations: when count == 31 (0..31)
                if (count == 32'd31) begin
                    busy <= 1'b0;

                    // Final restore + sign apply
                    quotient  <= Q_signed;
                    remainder <= R_signed;

                    done <= 1'b1;
                end
            end
        end
    end

endmodule
